+/* ─── WhatsApp Share Prompt ──────────────────────────────────────── */
+.wa-share-prompt {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  background: linear-gradient(135deg, rgba(37,211,102,0.08), rgba(37,211,102,0.03));
+  border: 1px solid rgba(37,211,102,0.2);
+  border-radius: 12px;
+  padding: 12px 16px;
+  margin: 8px 48px 8px 48px;
+  animation: waShareFadeIn 0.4s ease;
+  transition: opacity 0.3s ease;
+}
+
+@keyframes waShareFadeIn {
+  from { opacity: 0; transform: translateY(8px); }
+  to   { opacity: 1; transform: translateY(0); }
+}
+
+.wa-share-text {
+  flex: 1;
+  font-family: var(--font-body);
+  font-size: 0.82rem;
+  color: var(--text-secondary);
+  line-height: 1.4;
+}
+
+.wa-share-btn {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  background: #25D366;
+  color: #fff;
+  border: none;
+  border-radius: 8px;
+  padding: 8px 14px;
+  font-family: var(--font-ui);
+  font-size: 0.75rem;
+  font-weight: 600;
+  cursor: pointer;
+  white-space: nowrap;
+  transition: background 0.2s, transform 0.15s;
+}
+
+.wa-share-btn:hover {
+  background: #1DA851;
+  transform: scale(1.03);
+}
+
+.wa-share-btn:active {
+  transform: scale(0.97);
+}
+
+.wa-share-dismiss {
+  background: none;
+  border: none;
+  color: var(--text-muted);
+  font-size: 1rem;
+  cursor: pointer;
+  padding: 4px;
+  opacity: 0.5;
+  transition: opacity 0.2s;
+}
+
+.wa-share-dismiss:hover {
+  opacity: 1;
+}
+
+@media (max-width: 600px) {
+  .wa-share-prompt {
+    margin: 8px 8px;
+    flex-wrap: wrap;
+  }
+  .wa-share-text {
+    width: 100%;
+    margin-bottom: 4px;
+  }
+}
+
